---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import { aboutImages } from "../lib/images.ts";
import about from "../data/about.json";
import site from "../data/site.json";

const images = aboutImages();
const portrait = images[0];
const gallery = images.slice(1);
---

<BaseLayout title="About">
  <section class="section container about">
    <div class="about__grid">
      <div class="about__text">
        <h1>{about.heading}</h1>
        {about.paragraphs.map((p) => <p>{p}</p>)}
        <div class="about__links">
          <a class="btn btn--accent" href={`mailto:${site.email}`}>Get in touch</a>
          <a class="btn" href="/resume">View resume</a>
        </div>
      </div>
      {
        portrait && (
          <div class="about__portrait">
            <Image
              src={portrait.src}
              alt={portrait.alt}
              width={800}
              quality={82}
            />
          </div>
        )
      }
    </div>
  </section>

  {
    gallery.length > 0 && (
      <section class="section--tight container">
        <div class="about__gallery">
          {gallery.map((img) => (
            <figure>
              <Image
                src={img.src}
                alt={img.alt}
                width={700}
                quality={80}
              />
            </figure>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }
  @media (max-width: 820px) {
    .about__grid {
      grid-template-columns: 1fr;
    }
  }
  .about__portrait {
    background: var(--bg-alt);
  }
  .about__portrait :global(img) {
    width: 100%;
    height: auto;
  }
  .about__links {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .about__gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: clamp(1rem, 2.5vw, 1.6rem);
  }
  .about__gallery figure {
    margin: 0;
    background: var(--bg-alt);
  }
  .about__gallery :global(img) {
    width: 100%;
    height: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }
</style>
