---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Gallery from "../../components/Gallery.astro";
import { projectImages } from "../../lib/images.ts";
import presentations from "../../data/presentations.json";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects
    .filter((p) => p.id !== "internship-work")
    .map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const images = projectImages(project.id);
const hero = images[0];
const rest = images.slice(1);
const meta = project.data.meta ?? {};
const pdf = (presentations as Record<string, string>)[project.id];
const catLabel: Record<string, string> = {
  featured: "Featured Project",
  other: "Project",
  internship: "Project",
};
---

<BaseLayout title={project.data.title}>
  <article>
    <header class="section--tight container proj-head">
      <p class="eyebrow">{catLabel[project.data.category]}</p>
      <h1>{project.data.title}</h1>
    </header>

    {
      hero && (
        <div class="proj-hero container">
          <Image
            src={hero.src}
            alt={hero.alt}
            width={1600}
            quality={82}
            loading="eager"
          />
        </div>
      )
    }

    <div class="section container proj-body">
      {
        (Object.keys(meta).length > 0 || pdf) && (
          <aside class="proj-meta">
            <dl>
              {Object.entries(meta).map(([k, v]) => (
                <div class="proj-meta__row">
                  <dt>{k}</dt>
                  <dd>{v}</dd>
                </div>
              ))}
            </dl>
            {pdf && (
              <a class="btn proj-meta__pdf" href={pdf} target="_blank" rel="noopener">
                Download presentation (PDF)
              </a>
            )}
          </aside>
        )
      }
      <div class="proj-prose prose">
        <Content />
      </div>
    </div>

    {
      rest.length > 0 && (
        <div class="section--tight container">
          <Gallery images={rest} />
        </div>
      )
    }

    <div class="container proj-nav">
      <a class="btn" href="/portfolio">← All projects</a>
    </div>
  </article>
</BaseLayout>

<style>
  .proj-head {
    padding-bottom: 1.5rem;
  }
  .proj-hero {
    margin-bottom: clamp(1.5rem, 5vw, 3rem);
  }
  .proj-hero :global(img) {
    width: 100%;
    height: auto;
  }
  .proj-body {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }
  @media (max-width: 820px) {
    .proj-body {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
  .proj-meta {
    position: sticky;
    top: 90px;
  }
  .proj-meta__pdf {
    margin-top: 1.25rem;
    display: inline-block;
  }
  .proj-meta dl {
    margin: 0;
    border-top: 1px solid var(--line);
  }
  .proj-meta__row {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--line);
  }
  .proj-meta dt {
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-deep);
    margin-bottom: 0.2rem;
  }
  .proj-meta dd {
    margin: 0;
    font-size: 0.98rem;
    color: var(--ink);
  }
  .prose :global(p) {
    font-size: 1.05rem;
  }
  .proj-nav {
    padding-block: 2rem 1rem;
  }
</style>
